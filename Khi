            CountLabel.TextSize = 15
            CountLabel.TextXAlignment = Enum.TextXAlignment.Left
            
            RefreshBtn.Parent = MainFrame
            RefreshBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 220)
            RefreshBtn.BorderSizePixel = 0
            RefreshBtn.Position = UDim2.new(0, 10, 0, 85)
            RefreshBtn.Size = UDim2.new(1, -20, 0, 40)
            RefreshBtn.Font = Enum.Font.GothamBold
            RefreshBtn.Text = " تحديث"
            RefreshBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            RefreshBtn.TextSize = 15
            
            ScrollingFrame.Parent = MainFrame
            ScrollingFrame.Active = true
            ScrollingFrame.BackgroundColor3 = Color3.fromRGB(20, 23, 30)
            ScrollingFrame.BorderSizePixel = 0
            ScrollingFrame.Position = UDim2.new(0, 10, 0, 135)
            ScrollingFrame.Size = UDim2.new(1, -20, 1, -145)
            ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
            ScrollingFrame.ScrollBarThickness = 6
            
            UIListLayout.Parent = ScrollingFrame
            UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
            UIListLayout.Padding = UDim.new(0, 8)
            
            local function updateCount()
                CountLabel.Text = "الاغاني المكتشفة: " .. songCount
            end
            
            local function addSong(name, id, duration)
                if LoggedIDs[id] then return end
                LoggedIDs[id] = true
                songCount = songCount + 1
                updateCount()
                
                local SongFrame = Instance.new("Frame")
                SongFrame.Parent = ScrollingFrame
                SongFrame.BackgroundColor3 = Color3.fromRGB(30, 35, 45)
                SongFrame.Size = UDim2.new(1, -10, 0, 70)
                
                local NameLabel = Instance.new("TextLabel")
                NameLabel.Parent = SongFrame
                NameLabel.BackgroundTransparency = 1
                NameLabel.Position = UDim2.new(0, 10, 0, 10)
                NameLabel.Size = UDim2.new(1, -120, 0, 20)
                NameLabel.Font = Enum.Font.GothamBold
                NameLabel.Text = " " .. name
                NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                NameLabel.TextSize = 13
                NameLabel.TextXAlignment = Enum.TextXAlignment.Left
                
                local InfoLabel = Instance.new("TextLabel")
                InfoLabel.Parent = SongFrame
                InfoLabel.BackgroundTransparency = 1
                InfoLabel.Position = UDim2.new(0, 10, 0, 35)
                InfoLabel.Size = UDim2.new(1, -120, 0, 20)
                InfoLabel.Font = Enum.Font.Gotham
                InfoLabel.Text = "ID: " .. id .. " | " .. math.floor(duration) .. "s"
                InfoLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
                InfoLabel.TextSize = 11
                InfoLabel.TextXAlignment = Enum.TextXAlignment.Left
                
                local CopyBtn = Instance.new("TextButton")
                CopyBtn.Parent = SongFrame
                CopyBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
                CopyBtn.Position = UDim2.new(1, -100, 0.5, -15)
                CopyBtn.Size = UDim2.new(0, 90, 0, 30)
                CopyBtn.Font = Enum.Font.GothamBold
                CopyBtn.Text = " نسخ"
                CopyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                CopyBtn.TextSize = 14
                CopyBtn.MouseButton1Click:Connect(function()
                    setclipboard(id)
                    CopyBtn.Text = " تم"
                    task.wait(1.5)
                    CopyBtn.Text = " نسخ"
                end)
            end
            
            local function scanSongs()
                for _, v in pairs(game:GetDescendants()) do
                    if v:IsA("Sound") then
                        pcall(function()
                            local id = v.SoundId:match("%d+")
                            if id and v.TimeLength >= 20 then
                                addSong(v.Name ~= "" and v.Name or "أغنية", id, v.TimeLength)
                            end
                        end)
                    end
                end
            end
            
            RefreshBtn.MouseButton1Click:Connect(function()
                scanSongs()
            end)
            scanSongs()
        ]])()
    end,
})

