-- وظائف التجسس
-- ═══════════════════════════════════════
local function stopSpy()
    if not spyEnabled then return end
    spyEnabled = false
    pcall(function()
        local camera = Workspace.CurrentCamera
        if lp.Character and lp.Character:FindFirstChild("Humanoid") then
            camera.CameraSubject = lp.Character.Humanoid
        elseif originalCameraSubject then
            camera.CameraSubject = originalCameraSubject
        end
    end)
    spyTarget = nil
    Rayfield:Notify({ Title = "تجسس", Content = "تم إيقاف التجسس", Duration = 3 })
end

local function startSpy(target)
    if not target then
        Rayfield:Notify({ Title = "خطأ", Content = "الهدف غير موجود!", Duration = 3 })
        return
    end
    if not target.Character or not target.Character:FindFirstChild("Humanoid") then
        Rayfield:Notify({ Title = "خطأ", Content = "شخصية الهدف غير موجودة!", Duration = 3 })
        return
    end
    spyEnabled = true
    spyTarget = target
    pcall(function()
        local camera = Workspace.CurrentCamera
        originalCameraSubject = camera.CameraSubject
        camera.CameraSubject = target.Character.Humanoid
        Rayfield:Notify({ Title = "تجسس", Content = "بدأ التجسس على: " .. target.Name, Duration = 3 })
    end)
end

