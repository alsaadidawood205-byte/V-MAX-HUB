-- دالة لنسخ جميع التفاصيل بسرعة ودقة
local function copyAvatarAdvanced(TPlayer)
    if not TPlayer or not TPlayer.Character then
        Rayfield:Notify({ Title = "خطأ", Content = "اللاعب غير موجود!", Duration = 3 })
        return false
    end
    
    if copyInProgress then
        Rayfield:Notify({ Title = "تنبيه", Content = "يوجد نسخ قيد التنفيذ... انتظر قليلاً", Duration = 3 })
        return false
    end
    
    copyInProgress = true
    
    local LChar = lp.Character
    local LHumanoid = LChar and LChar:FindFirstChildOfClass("Humanoid")
    local THumanoid = TPlayer.Character:FindFirstChildOfClass("Humanoid")
    
    if not LHumanoid or not THumanoid then
        copyInProgress = false
        Rayfield:Notify({ Title = "خطأ", Content = "تعذر العثور على الهيئة!", Duration = 3 })
        return false
    end
    
    Rayfield:Notify({ Title = "نسخ سكنات", Content = "جاري نسخ سكنة: " .. TPlayer.Name, Duration = 5 })
    
    task.spawn(function()
        pcall(function()
            -- 1. حفظ التفاصيل الأصلية للاعب
            local LDesc = LHumanoid:GetAppliedDescription()
            local PDesc = THumanoid:GetAppliedDescription()
            
            -- 2. إزالة الملابس الحالية بسرعة
            local accessoriesToRemove = {}
            for _, acc in ipairs(LDesc:GetAccessories(true)) do
                if acc.AssetId and tonumber(acc.AssetId) then
                    table.insert(accessoriesToRemove, tonumber(acc.AssetId))
                end
            end
            
            for _, assetId in ipairs(accessoriesToRemove) do
                pcall(function() Remotes.Wear:InvokeServer(assetId) end)
                task.wait(0.15)
            end
            
            if tonumber(LDesc.Shirt) then
                pcall(function() Remotes.Wear:InvokeServer(tonumber(LDesc.Shirt)) end)
                task.wait(0.15)
            end
            if tonumber(LDesc.Pants) then
                pcall(function() Remotes.Wear:InvokeServer(tonumber(LDesc.Pants)) end)
                task.wait(0.15)
            end
            if tonumber(LDesc.Face) then
                pcall(function() Remotes.Wear:InvokeServer(tonumber(LDesc.Face)) end)
                task.wait(0.15)
            end
            
            -- 3. نسخ جسم الهدف
            local argsBody = {[1] = {
                [1] = PDesc.Torso,
                [2] = PDesc.RightArm,
                [3] = PDesc.LeftArm,
                [4] = PDesc.RightLeg,
                [5] = PDesc.LeftLeg,
                [6] = PDesc.Head
            }}
            pcall(function() Remotes.ChangeCharacterBody:InvokeServer(unpack(argsBody)) end)
            task.wait(1)
            
            -- 4. نسخ الملابس
            if tonumber(PDesc.Shirt) then
                pcall(function() Remotes.Wear:InvokeServer(tonumber(PDesc.Shirt)) end)
                task.wait(0.2)
            end
            if tonumber(PDesc.Pants) then
                pcall(function() Remotes.Wear:InvokeServer(tonumber(PDesc.Pants)) end)
                task.wait(0.2)
            end
            if tonumber(PDesc.Face) then
                pcall(function() Remotes.Wear:InvokeServer(tonumber(PDesc.Face)) end)
                task.wait(0.2)
            end
            
            -- 5. نسخ الإكسسوارات
            local accessoriesToCopy = {}
            for _, acc in ipairs(PDesc:GetAccessories(true)) do
                if acc.AssetId and tonumber(acc.AssetId) then
                    table.insert(accessoriesToCopy, tonumber(acc.AssetId))
                end
            end
            
            for _, assetId in ipairs(accessoriesToCopy) do
                pcall(function() Remotes.Wear:InvokeServer(assetId) end)
                task.wait(0.15)
            end
            
            -- 6. نسخ لون البشرة
            local SkinColor = TPlayer.Character:FindFirstChild("Body Colors")
            if SkinColor then
                pcall(function() Remotes.ChangeBodyColor:FireServer(tostring(SkinColor.HeadColor)) end)
                task.wait(0.2)
            end
            
            -- 7. نسخ الأنيميشنات
            local AnimationsToCopy = {
                IdleAnimation = PDesc.IdleAnimation,
                WalkAnimation = PDesc.WalkAnimation,
                RunAnimation = PDesc.RunAnimation,
                JumpAnimation = PDesc.JumpAnimation,
                SwimAnimation = PDesc.SwimAnimation,
                FallAnimation = PDesc.FallAnimation,
                ClimbAnimation = PDesc.ClimbAnimation
            }
            
            for animName, animId in pairs(AnimationsToCopy) do
                if tonumber(animId) then
                    pcall(function() Remotes.Wear:InvokeServer(tonumber(animId)) end)
                    task.wait(0.15)
                end
            end
            
            -- 8. نسخ اسم RP والبايو
            local Bag = TPlayer:FindFirstChild("PlayersBag")
            if Bag then
                if Bag:FindFirstChild("RPName") and Bag.RPName.Value ~= "" then
                    pcall(function() Remotes.RPNameText:FireServer("RolePlayName", Bag.RPName.Value) end)
                    task.wait(0.2)
                end
                if Bag:FindFirstChild("RPBio") and Bag.RPBio.Value ~= "" then
                    pcall(function() Remotes.RPNameText:FireServer("RolePlayBio", Bag.RPBio.Value) end)
                    task.wait(0.2)
                end
                if Bag:FindFirstChild("RPNameColor") then
                    pcall(function() Remotes.RPNameColor:FireServer("PickingRPNameColor", Bag.RPNameColor.Value) end)
                    task.wait(0.15)
                end
                if Bag:FindFirstChild("RPBioColor") then
                    pcall(function() Remotes.RPNameColor:FireServer("PickingRPBioColor", Bag.RPBioColor.Value) end)
                    task.wait(0.15)
                end
            end
            
            -- 9. نسخ المظهر الخاص
            if PDesc.SpecialAppearance then
                pcall(function() Remotes.Wear:InvokeServer(PDesc.SpecialAppearance) end)
                task.wait(0.2)
            end
            
            -- 10. تحديث الشخصية
            pcall(function()
                if LHumanoid then
                    LHumanoid:ApplyDescription(PDesc)
                end
            end)
            
            Rayfield:Notify({ Title = "نسخ سكنات", Content = "تم النسخ بنجاح!", Duration = 3 })
        end)
        
        copyInProgress = false
    end)
    
    return true
end

