-- ========== [ قسم المضادات ] ==========
Tabs.Anti:AddToggle("AntiBangToggle", {
    Title = "مضاد بانج",
    Description = "ينقلك لمكان آمن بعيداً عن اللاعبين",
    Default = false,
    Callback = function(state)
        local character = lp.Character or lp.CharacterAdded:Wait()
        local hrp = character:WaitForChild("HumanoidRootPart")
        local function createTween(targetCFrame) return TweenService:Create(hrp, TweenInfo.new(antiBangTeleportTime, Enum.EasingStyle.Linear), {CFrame = targetCFrame}) end

        if state then
            antiBangLastPos = hrp.Position
            local part = Instance.new("Part")
            part.Size = Vector3.new(4, 1, 4)
            part.Position = antiBangLastPos
            part.Anchored = true; part.CanCollide = false; part.Transparency = 0.5; part.Name = "Gaze"; part.Parent = Workspace
            Workspace.CurrentCamera.CameraSubject = part
            antiBangToggle = true
            Workspace.FallenPartsDestroyHeight = -1000
            local tweenToTarget = createTween(CFrame.new(antiBangTargetPos))
            tweenToTarget:Play()
            tweenToTarget.Completed:Wait()
            antiBangVelConn = RunService.Heartbeat:Connect(function() if antiBangToggle then hrp.Velocity = Vector3.zero end end)
            Fluent:Notify({Title = "مضادات", Content = "تم تفعيل مضاد بانج", Duration = 3})
        else
            antiBangToggle = false
            if antiBangVelConn then antiBangVelConn:Disconnect() end
            local tweenBack = createTween(CFrame.new(antiBangLastPos))
            tweenBack:Play()
            tweenBack.Completed:Wait()
            Workspace.FallenPartsDestroyHeight = -500
            if lp.Character and lp.Character:FindFirstChild("Humanoid") then Workspace.CurrentCamera.CameraSubject = lp.Character.Humanoid end
            if Workspace:FindFirstChild("Gaze") then Workspace.Gaze:Destroy() end
            Fluent:Notify({Title = "مضادات", Content = "تم العودة للموقع الأصلي", Duration = 3})
        end
    end
})

